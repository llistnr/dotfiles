[global]

# general
markup = yes
notification_limit = 1
enable_posix_regex = true
override_dbus_timeout = 0
stack_duplicates = false
show_indicators = no

# geometry
width = 3032
padding = 20
horizontal_padding = 0
offset = 20 x -40
frame_width = 0
origin = top-left
layer = top

# style
font = RobotoMono Nerd Font Propo 11
format = "<b>%a</b> | <b>%s</b> | %b"
ignore_newline = true
word_wrap = false
icon_position = off
ellipsize = middle
alignment = left
background = "#00000000"
foreground = "#FAFAFA"

# mouse
mouse_left_click = do_action, close_current
mouse_middle_click = close_all
mouse_right_click = close_current

