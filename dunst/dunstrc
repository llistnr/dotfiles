[global]

# general
notification_limit = 1
enable_posix_regex = true
override_dbus_timeout = 0
stack_duplicates = false

# geometry
width = 600
height = 500
padding = 40
horizontal_padding = 40
frame_width = 0
origin = center

# style
font = RobotoMono Nerd Font Propo 11
format = <b>[%a] %s</b>\n%b
icon_position = off
background = "#000000"
foreground = "#FAFAFA"

