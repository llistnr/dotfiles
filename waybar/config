{
    "margin": "40 20 20 20",
    "spacing": 40,
    "modules-left": ["clock", "hyprland/workspaces", "hyprland/window"],
    "modules-right": ["pulseaudio", "cpu", "memory", "network", "custom/notification"],
    "clock": {
        "format": "{:%A %B %d %H:%M}",
        "tooltip": false,
    },
    "hyprland/workspaces": {
        "format": "workspace {name}",
        "active-only": true,
    },
    "cpu": {
        "format": "cpu {usage:03}",
        "interval": 10,
        "tooltip": false,
    },
    "memory": {
        "format": "ram {:03}",
        "interval": 10,
        "tooltip": false,
    },
    "network": {
        "format-wifi": "wifi {essid}",
        "format-ethernet": "ethernet {ipaddr}",
        "format-disconnected": "network disconnected",
        "tooltip": false,
    },
    "pulseaudio": {
        "format": "audio {volume:03}",
        "format-muted": "audio XXX",
        "on-click": "pactl set-sink-mute 0 toggle",
        "on-scroll-up": "pactl set-sink-volume 0 +5%",
        "on-scroll-down": "pactl set-sink-volume 0 -5%",
        "scroll-step": 1,
        "tooltip": false,
    },
    "custom/notification": {
        "format": "notifications {icon}",
        "format-icons": {
            "notification": "<span foreground='red'><sup></sup></span>",
            "none": "",
            "dnd-notification": "<span foreground='red'><sup></sup></span>",
            "dnd-none": "",
            "inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "inhibited-none": "",
            "dnd-inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "dnd-inhibited-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip": false,
    },
}

